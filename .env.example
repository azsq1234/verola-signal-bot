# Copy this file to .env and fill in your values.

# Your Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# The Telegram channel ID where signals will be broadcast
# For public channels use @channelname, for private channels use the numeric ID (e.g. -1001234567890)
CHANNEL_ID=@your_channel_name

# (Optional) Exchange to use — defaults to binance (public data, no key required)
EXCHANGE_ID=binance
